{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gengou.schema.json",
  "title": "GengouKnowledge",
  "type": "object",
  "required": ["version", "description", "items"],
  "additionalProperties": false,
  "properties": {
    "version":     { "type": "string" },
    "description": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/GengouEntry" }
    }
  },
  "definitions": {
    "GengouEntry": {
      "type": "object",
      "required": ["name", "yomi", "start_year", "end_year", "period", "common_variants", "common_misreads"],
      "additionalProperties": false,
      "properties": {
        "name":       { "type": "string", "minLength": 2, "maxLength": 3 },
        "yomi":       { "type": "string", "minLength": 1 },
        "start_year": { "type": "integer", "minimum": 1000 },
        "end_year":   { "type": ["integer", "null"], "minimum": 1000 },
        "period":     { "type": "string", "enum": ["edo", "modern"] },
        "common_variants": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "common_misreads": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        }
      }
    }
  }
}
