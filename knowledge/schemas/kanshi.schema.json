{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kanshi.schema.json",
  "title": "KanshiKnowledge",
  "type": "object",
  "required": ["version", "description", "items"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 60,
      "maxItems": 60,
      "items": { "$ref": "#/definitions/KanshiEntry" }
    }
  },
  "definitions": {
    "KanshiEntry": {
      "type": "object",
      "required": ["index", "kanji", "yomi", "kan", "shi", "gogyou", "common_misreads"],
      "additionalProperties": false,
      "properties": {
        "index":  { "type": "integer", "minimum": 1, "maximum": 60 },
        "kanji":  { "type": "string", "minLength": 2, "maxLength": 2 },
        "yomi":   { "type": "string", "minLength": 1 },
        "kan":    { "type": "string", "enum": ["甲","乙","丙","丁","戊","己","庚","辛","壬","癸"] },
        "shi":    { "type": "string", "enum": ["子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"] },
        "gogyou": { "type": "string", "enum": ["木","火","土","金","水"] },
        "common_misreads": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
