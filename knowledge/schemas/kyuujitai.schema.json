{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kyuujitai.schema.json",
  "title": "KyuujitaiKnowledge",
  "type": "object",
  "required": ["version", "description", "note", "items"],
  "additionalProperties": false,
  "properties": {
    "version":     { "type": "string" },
    "description": { "type": "string" },
    "note":        { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 50,
      "items": { "$ref": "#/definitions/KyuujitaiEntry" }
    }
  },
  "definitions": {
    "KyuujitaiEntry": {
      "type": "object",
      "required": ["old", "new", "yomi", "category"],
      "additionalProperties": false,
      "properties": {
        "old":      { "type": "string", "minLength": 1, "maxLength": 1 },
        "new":      { "type": "string", "minLength": 1, "maxLength": 1 },
        "yomi":     { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 }
      }
    }
  }
}
